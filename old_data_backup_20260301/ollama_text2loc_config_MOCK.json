{
  "ollama": {
    "url": "http://localhost:11434",
    "timeout": 30,
    "model": "qwen3-vl:4b",
    "embedding_model": "qwen3-embedding:0.6b",
    "optimized_model": "text2loc-optimized",
    "options": {
      "gpu_layers": 15,
      "num_threads": 8,
      "batch_size": 32,
      "flash_attention": true,
      "num_predict": 256,
      "temperature": 0.1,
      "top_k": 20,
      "top_p": 0.9,
      "repeat_penalty": 1.1,
      "presence_penalty": 0.1,
      "frequency_penalty": 0.1,
      "mirostat": 0,
      "mirostat_tau": 5.0,
      "mirostat_eta": 0.1,
      "seed": -1,
      "tfs_z": 1.0,
      "typical_p": 1.0,
      "repeat_last_n": 64,
      "penalize_nl": true,
      "memory_optimization": {
        "kv_cache_cpu_ratio": 0.3,
        "kv_cache_gpu_ratio": 0.7,
        "offload_layers_to_gpu": true,
        "mmap": true,
        "mlock": false
      }
    },
    "retry_policy": {
      "max_retries": 3,
      "retry_delay": 2,
      "backoff_factor": 1.5
    }
  },
  "memory_management": {
    "max_cache_size": 1000,
    "cache_ttl": 3600,
    "session_ttl": 1800,
    "gpu_memory_limit_gb": 6.0
  },
  "text2loc_integration": {
    "template_families": [
      "base",
      "natural",
      "hybrid",
      "minimal",
      "spatial"
    ],
    "clarification_max_rounds": 5,
    "confidence_threshold": 0.7,
    "fallback_to_mock": true
  }
}